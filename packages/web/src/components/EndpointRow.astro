---
interface Props {
  method: 'GET' | 'POST' | 'PATCH' | 'DELETE';
  route: string;
  price: string;
  description: string;
}

const { method, route, price, description } = Astro.props;
const methodClass = method.toLowerCase();
const isFree = price === 'free';
---
<tr>
  <td><span class={`method ${methodClass}`}>{method}</span></td>
  <td><span class="route">{route}</span></td>
  <td><span class={`price ${isFree ? 'free' : ''}`}>{price}</span></td>
  <td class="desc">{description}</td>
</tr>

<style>
  td {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 0.82rem;
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.015); }

  .method {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius);
    display: inline-block;
    min-width: 52px;
    text-align: center;
  }

  .method.get    { background: rgba(0,255,148,0.1);   color: var(--success); }
  .method.post   { background: rgba(124,106,247,0.1); color: var(--accent-soft); }
  .method.patch  { background: rgba(251,191,36,0.1);  color: #fbbf24; }
  .method.delete { background: rgba(248,113,113,0.1); color: #f87171; }

  .route {
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .price {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: #4fc3f7;
    white-space: nowrap;
  }

  .price.free { color: var(--text-muted); }

  .desc { color: var(--text-muted); }
</style>
